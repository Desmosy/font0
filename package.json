{
  "name": "font-generator",
  "version": "0.1.0",
  "private": false,
  "description": "Prompt-driven variable font generator with browser-side font export.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 3939",
    "dev:clean": "rm -rf .next && next dev -p 3939",
    "build": "next build",
    "start": "next start -p 3939",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "harfbuzzjs": "^0.4.6",
    "next": "^15.1.12",
    "opentype.js": "^1.3.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/opentype.js": "^1.3.8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^6"
  }
}
