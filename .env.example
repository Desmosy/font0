# NVIDIA NIM (OpenAI-compatible) endpoint for prompt -> font parameters.
# Get a key at https://build.nvidia.com. Keep it server-side only.
# Leave this placeholder in place to use the local keyword fallback.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Optional server-side safety limits for /api/generate.
GENERATE_RATE_LIMIT=30
GENERATE_RATE_WINDOW_MS=60000
NVIDIA_TIMEOUT_MS=60000
